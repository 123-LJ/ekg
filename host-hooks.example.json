{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{EKG_ROOT}}/hooks/pre-edit.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{EKG_ROOT}}/hooks/task-complete.js\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{EKG_ROOT}}/hooks/task-complete.js\""
          }
        ]
      }
    ]
  }
}
