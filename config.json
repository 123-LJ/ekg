{
  "version": "1.0.0",
  "name": "EKG",
  "stage": "phase-1",
  "description": "Experience Knowledge Graph for AI coding collaboration.",
  "storage": {
    "backend": "sqlite",
    "outputDir": "ekg-out",
    "legacyMirror": true,
    "indexFile": "ekg.json",
    "stateFile": "state.json",
    "experienceDir": "experiences",
    "reportFile": "reports/EKG_REPORT.md",
    "sqliteFile": "ekg-out/ekg.sqlite"
  },
  "enums": {
    "confidence": ["CONFIRMED", "INFERRED", "UNCERTAIN"],
    "status": ["ACTIVE", "NEEDS_REVIEW", "STALE", "ARCHIVED"],
    "experienceLevel": ["L1", "L2", "L3"],
    "experienceType": ["bug-fix", "convention", "decision", "workflow", "seed"]
  },
  "query": {
    "defaultLimit": 5,
    "detailScoreThreshold": 8,
    "pathWeight": 4,
    "tagWeight": 3,
    "textWeight": 1
  },
  "concurrency": {
    "enabled": true,
    "lockFile": ".ekg.lock",
    "staleLockMs": 30000,
    "retryIntervalMs": 100,
    "maxWaitMs": 5000,
    "readRetryCount": 5,
    "readRetryIntervalMs": 30
  },
  "hook": {
    "enabled": true,
    "defaultInjectionLevel": "Level 1",
    "maxInjectedExperiences": 3,
    "minimumScore": 5,
    "dedupeWindowMinutes": 120,
    "levels": {
      "Level 0": "No output when no relevant experience is found.",
      "Level 1": "Inject a one-line summary when a related experience is found.",
      "Level 2": "Inject detailed guidance for high-confidence direct matches."
    }
  },
  "capture": {
    "enabled": true,
    "pendingLimit": 20,
    "dedupeWindowMinutes": 180,
    "minimumSummaryLength": 24,
    "requireFileAnchor": true,
    "defaultType": "workflow",
    "defaultLevel": "L1",
    "defaultConfidence": "UNCERTAIN",
    "defaultStatus": "NEEDS_REVIEW",
    "gate": {
      "enabled": true,
      "blockOnEvents": ["Stop"]
    }
  },
  "seed": {
    "enabled": true,
    "minimumSeedCount": 2
  }
}
